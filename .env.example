# Toggle ads on/off for the whole build (SDK, plugin, manifest entries)
EXPO_PUBLIC_ENABLE_ADS=false

# AdMob — fill with your own IDs from https://admob.google.com
# App IDs (format: ca-app-pub-XXXXXXXX~XXXXXXXX)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-0000000000000000~0000000000
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-0000000000000000~0000000000

# Banner ad unit IDs (format: ca-app-pub-XXXXXXXX/XXXXXXXX)
EXPO_PUBLIC_ADMOB_BANNER_ANDROID_ID=ca-app-pub-0000000000000000/0000000000
EXPO_PUBLIC_ADMOB_BANNER_IOS_ID=ca-app-pub-0000000000000000/0000000000
